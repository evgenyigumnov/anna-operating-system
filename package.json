{
  "name": "anna-operating-system",
  "version": "0.0.2",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "start": "npm run build && node ./node_modules/electron/cli.js --no-sandbox .",
    "build:exe": "npm run build && node ./node_modules/electron-builder/out/cli/cli.js --win portable",
    "build:linux": "npm run build && node ./node_modules/electron-builder/out/cli/cli.js --linux",
    "build:mac": "npm run build && node ./node_modules/electron-builder/out/cli/cli.js --mac"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "imapflow": "^1.2.15",
    "mailparser": "^3.9.4",
    "nodemailer": "^8.0.2",
    "openai": "^6.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^36.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.evgenyigumnov.anna-operating-system",
    "productName": "Anna Operating System",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "IDENTITY.md",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Anna-Operating-System-${version}-portable.exe"
    }
  }
}
